---
interface Token {
  name: string;
  symbol: string;
  trustScore: number;
  slug: string;
  network?: string;
  market?: {
    priceUsd?: number;
    marketCap?: number;
    volume24h?: number;
    liquidityUsd?: number;
  };
  potentialScore?: number;
}

interface Props {
  tokens: Token[];
}

const { tokens } = Astro.props;

const scored = tokens.map((t) => ({
  ...t,
  hypeScore:
    (t.potentialScore ?? 0) +
    (t.trustScore ?? 0) * 0.5 +
    Math.log10((t.market?.volume24h ?? 1) + 1) * 10 +
    Math.log10((t.market?.marketCap ?? 1) + 1) * 5,
}));

const top5 = scored
  .sort((a, b) => b.hypeScore - a.hypeScore)
  .slice(0, 5);

const dupSlides = [...top5, ...top5];

const phrases = [
  "Security Audits",
  "Trust Scores",
  "Scam Detection",
  "Market Analysis",
];
---

<section class="hero-slider">
  <div class="intro">
    <h1 class="intro-title">
      <span class="line-animate">
        <span class="word-move" style="--dx:-30px;--dy:0">Real&#x2011;Time</span>
        <span class="word-move" style="--dx:30px;--dy:0">Token</span>
      </span>
      <span class="rotating-text">
        {phrases.map((p, i) => (
          <span class="word" style={`--i: ${i}; --n: ${phrases.length}`}>{p}</span>
        ))}
      </span>
    </h1>
    <p class="intro-sub">
      Live security analysis, trust scores &amp; scam detection for <strong>{tokens.length}+</strong> tokens
      across Ethereum, BSC &amp; Solana.
    </p>
  </div>

  <div class="carousel-wrap">
    <div class="carousel">
      {dupSlides.map((t, i) => {
        const color =
          t.trustScore >= 86 ? "#4488ff" :
          t.trustScore >= 70 ? "#44cc66" :
          t.trustScore >= 31 ? "#ccaa22" :
          "#dd4444";
        return (
          <a href={`/token/${t.slug}`} class="slide">
            <div class="slide-rank">#{i < 5 ? i + 1 : i - 4}</div>
            <div class="slide-body">
              <div class="slide-head">
                <span class="slide-name">{t.name}</span>
                <span class="slide-sym">{t.symbol}</span>
              </div>
              <div class="slide-meta">
                <span class="slide-network">{t.network || t.chain}</span>
                {t.market?.priceUsd && (
                  <span class="slide-price">${t.market.priceUsd.toFixed(8)}</span>
                )}
              </div>
              <div class="slide-bar">
                <div class="slide-bar-fill" style={`width: ${t.trustScore}%; background: ${color}`}></div>
              </div>
            </div>
            <div class="slide-score" style={`color: ${color}`}>
              {t.trustScore}
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <div class="hero-stats">
    <div class="hero-stat">
      <span class="hero-num">{tokens.length}</span>
      <span class="hero-label">Tokens Tracked</span>
    </div>
    <div class="hero-stat">
      <span class="hero-num">{tokens.filter((t) => t.trustScore >= 70).length}</span>
      <span class="hero-label">Safe Tokens</span>
    </div>
    <div class="hero-stat">
      <span class="hero-num">{tokens.filter((t) => t.trustScore < 31).length}</span>
      <span class="hero-label">High Risk</span>
    </div>
  </div>
</section>

<style>
  .hero-slider {
    padding: 4rem 0 2rem;
    text-align: center;
    position: relative;
  }

  .hero-slider::before {
    content: '// SYSTEM STATUS: ACTIVE';
    position: absolute;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: rgba(0,240,255,0.3);
    font-weight: 500;
  }

  .intro-title {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.3;
    min-height: 3.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.25rem;
  }

  .line-animate {
    display: inline-flex;
    gap: 0.4rem;
    overflow: hidden;
  }

  .word-move {
    display: inline-block;
    color: #e8f0ff;
    text-shadow: 0 0 20px rgba(0,240,255,0.15);
    opacity: 0;
    transform: translate(var(--dx), 20px);
    animation: wordEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.2s;
  }

  .line-animate .word-move:nth-child(2) {
    animation-delay: 0.4s;
  }

  @keyframes wordEnter {
    0% { opacity: 0; transform: translate(var(--dx), 20px); filter: blur(4px); }
    100% { opacity: 1; transform: translate(0, 0); filter: blur(0); }
  }

  .rotating-text {
    position: relative;
    display: inline-block;
    background: linear-gradient(135deg, #00f0ff, #0088cc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    min-width: 220px;
    text-shadow: 0 0 30px rgba(0,240,255,0.2);
    opacity: 0;
    animation: wordEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.6s;
    transform: translateY(20px);
  }

  .word {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    text-align: left;
    opacity: 0;
    transform: translateY(8px);
    animation: rotateWords 9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: calc(var(--i) * 3s);
  }

  @keyframes rotateWords {
    0%, 20% { opacity: 0; transform: translateY(8px); }
    5%, 15% { opacity: 1; transform: translateY(0); }
    25%, 100% { opacity: 0; transform: translateY(-8px); }
  }

  .intro-sub {
    margin-top: 1.2rem;
    font-size: 0.85rem;
    color: #6a7a8a;
    max-width: 550px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
    letter-spacing: 0.02em;
    opacity: 0;
    animation: wordEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.8s;
    transform: translateY(15px);
  }
  .intro-sub strong { color: #88b8d8; }

  .carousel-wrap {
    margin: 2rem auto 0;
    max-width: 780px;
    overflow: hidden;
    mask: linear-gradient(90deg, transparent 0%, #000 4%, #000 96%, transparent 100%);
    -webkit-mask: linear-gradient(90deg, transparent 0%, #000 4%, #000 96%, transparent 100%);
  }

  .carousel {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    animation: slideScroll 24s linear infinite;
  }
  .carousel:hover { animation-play-state: paused; }

  @keyframes slideScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .slide:nth-child(1) { animation-delay: 0s; }
  .slide:nth-child(2) { animation-delay: 0.05s; }
  .slide:nth-child(3) { animation-delay: 0.1s; }
  .slide:nth-child(4) { animation-delay: 0.15s; }
  .slide:nth-child(5) { animation-delay: 0.2s; }
  .slide:nth-child(6) { animation-delay: 0.25s; }

  .slide {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    background: linear-gradient(135deg, rgba(10,12,20,0.9), rgba(8,10,18,0.95));
    border: 1px solid rgba(0,240,255,0.06);
    border-radius: 8px;
    min-width: 300px;
    flex-shrink: 0;
    transition: all 0.3s;
    position: relative;
  }

  .slide::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 9px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(0,240,255,0.1), transparent, rgba(0,200,255,0.05));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .slide:hover {
    border-color: rgba(0,240,255,0.2);
    background: rgba(12,16,28,0.95);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .slide:hover::before {
    background: linear-gradient(135deg, rgba(0,240,255,0.25), transparent, rgba(0,200,255,0.1));
  }

  .slide-rank {
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(0,240,255,0.35);
    width: 1.6rem;
    text-align: center;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .slide-body {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .slide-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .slide-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #d0dce8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .slide-sym {
    font-size: 0.65rem;
    color: #4a5a6a;
    white-space: nowrap;
  }

  .slide-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.15rem;
  }

  .slide-network {
    font-size: 0.6rem;
    background: rgba(0,240,255,0.06);
    color: rgba(0,240,255,0.5);
    padding: 0.05rem 0.4rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .slide-price {
    font-size: 0.65rem;
    color: #5a6a7a;
    font-variant-numeric: tabular-nums;
  }

  .slide-bar {
    height: 2px;
    background: rgba(255,255,255,0.04);
    border-radius: 1px;
    margin-top: 0.4rem;
    overflow: hidden;
  }

  .slide-bar-fill {
    height: 100%;
    border-radius: 1px;
    transition: width 0.6s ease;
    box-shadow: 0 0 6px currentColor;
  }

  .slide-score {
    font-size: 0.95rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    margin-top: 2rem;
    opacity: 0;
    animation: wordEnter 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 1s;
    transform: translateY(15px);
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .hero-stat::after {
    content: '';
    position: absolute;
    bottom: -0.4rem;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,240,255,0.15), transparent);
  }

  .hero-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e0ecf8;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 0 20px rgba(0,240,255,0.1);
  }

  .hero-label {
    font-size: 0.65rem;
    color: #4a5a6a;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.15rem;
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .intro-title { font-size: 1.3rem; }
    .hero-slider { padding: 2.5rem 0 1.5rem; }
    .hero-slider::before { display: none; }
    .hero-stats { gap: 1.5rem; }
    .slide { min-width: 230px; padding: 0.5rem 0.65rem; }
  }
</style>
