---
interface Token {
  name: string;
  symbol: string;
  trustScore: number;
  slug: string;
  network?: string;
  market?: {
    priceUsd?: number;
    marketCap?: number;
    volume24h?: number;
    liquidityUsd?: number;
  };
  potentialScore?: number;
}

interface Props {
  tokens: Token[];
}

const { tokens } = Astro.props;

const scored = tokens.map((t) => ({
  ...t,
  hypeScore:
    (t.potentialScore ?? 0) +
    (t.trustScore ?? 0) * 0.5 +
    Math.log10((t.market?.volume24h ?? 1) + 1) * 10 +
    Math.log10((t.market?.marketCap ?? 1) + 1) * 5,
}));

const top5 = scored
  .sort((a, b) => b.hypeScore - a.hypeScore)
  .slice(0, 5);

const dupSlides = [...top5, ...top5];

const phrases = [
  "Security Audits",
  "Trust Scores",
  "Scam Detection",
  "Market Analysis",
];
---

<section class="hero-slider">
  <div class="intro">
    <h1 class="intro-title">
      Real&#x2011;Time Token
      <span class="rotating-text">
        {phrases.map((p, i) => (
          <span class="word" style={`--i: ${i}; --n: ${phrases.length}`}>{p}</span>
        ))}
      </span>
    </h1>
    <p class="intro-sub">
      Live security analysis, trust scores &amp; scam detection for <strong>{tokens.length}+</strong> tokens
      across Ethereum, BSC &amp; Solana.
    </p>
  </div>

  <div class="carousel-wrap">
    <div class="carousel">
      {dupSlides.map((t, i) => {
        const color =
          t.trustScore >= 86 ? "#4488ff" :
          t.trustScore >= 70 ? "#44cc66" :
          t.trustScore >= 31 ? "#ccaa22" :
          "#dd4444";
        return (
          <a href={`/token/${t.slug}`} class="slide">
            <div class="slide-rank">#{i < 5 ? i + 1 : i - 4}</div>
            <div class="slide-body">
              <div class="slide-head">
                <span class="slide-name">{t.name}</span>
                <span class="slide-sym">{t.symbol}</span>
              </div>
              <div class="slide-meta">
                <span class="slide-network">{t.network || t.chain}</span>
                {t.market?.priceUsd && (
                  <span class="slide-price">${t.market.priceUsd.toFixed(8)}</span>
                )}
              </div>
              <div class="slide-bar">
                <div class="slide-bar-fill" style={`width: ${t.trustScore}%; background: ${color}`}></div>
              </div>
            </div>
            <div class="slide-score" style={`color: ${color}`}>
              {t.trustScore}
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <div class="hero-stats">
    <div class="hero-stat">
      <span class="hero-num">{tokens.length}</span>
      <span class="hero-label">Tokens Tracked</span>
    </div>
    <div class="hero-stat">
      <span class="hero-num">{tokens.filter((t) => t.trustScore >= 70).length}</span>
      <span class="hero-label">Safe Tokens</span>
    </div>
    <div class="hero-stat">
      <span class="hero-num">{tokens.filter((t) => t.trustScore < 31).length}</span>
      <span class="hero-label">High Risk</span>
    </div>
  </div>
</section>

<style>
  .hero-slider {
    padding: 3.5rem 0 2rem;
    text-align: center;
  }

  .intro-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.3;
    min-height: 3.2rem;
  }

  .rotating-text {
    position: relative;
    display: inline-block;
    background: linear-gradient(135deg, #6c8cff, #8c6cff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    min-width: 240px;
  }

  .word {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    text-align: left;
    opacity: 0;
    transform: translateY(8px);
    animation: rotateWords 9s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    animation-delay: calc(var(--i) * 3s);
  }

  @keyframes rotateWords {
    0%, 20% { opacity: 0; transform: translateY(8px); }
    5%, 15% { opacity: 1; transform: translateY(0); }
    25%, 100% { opacity: 0; transform: translateY(-8px); }
  }

  .intro-sub {
    margin-top: 1rem;
    font-size: 1rem;
    color: #888;
    max-width: 550px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }
  .intro-sub strong { color: #bbb; }

  .carousel-wrap {
    margin: 2rem auto 0;
    max-width: 780px;
    overflow: hidden;
    mask: linear-gradient(90deg, transparent 0%, #000 4%, #000 96%, transparent 100%);
    -webkit-mask: linear-gradient(90deg, transparent 0%, #000 4%, #000 96%, transparent 100%);
  }

  .carousel {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    animation: slideScroll 24s linear infinite;
  }
  .carousel:hover { animation-play-state: paused; }

  @keyframes slideScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .slide {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: linear-gradient(135deg, rgba(26,26,36,0.8), rgba(22,22,32,0.9));
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    min-width: 300px;
    flex-shrink: 0;
    transition: all 0.25s;
  }
  .slide:hover {
    border-color: rgba(108,140,255,0.3);
    background: rgba(30,30,42,0.95);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .slide-rank {
    font-size: 0.75rem;
    font-weight: 700;
    color: #555;
    width: 1.6rem;
    text-align: center;
    flex-shrink: 0;
  }

  .slide-body {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .slide-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .slide-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .slide-sym {
    font-size: 0.7rem;
    color: #666;
    white-space: nowrap;
  }

  .slide-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.15rem;
  }

  .slide-network {
    font-size: 0.65rem;
    background: rgba(255,255,255,0.06);
    color: #888;
    padding: 0.05rem 0.45rem;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .slide-price {
    font-size: 0.7rem;
    color: #777;
    font-variant-numeric: tabular-nums;
  }

  .slide-bar {
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    margin-top: 0.4rem;
    overflow: hidden;
  }

  .slide-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.6s ease;
  }

  .slide-score {
    font-size: 1rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }

  .hero-label {
    font-size: 0.75rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.15rem;
  }

  @media (max-width: 600px) {
    .intro-title { font-size: 1.6rem; }
    .hero-slider { padding: 2rem 0 1.5rem; }
    .hero-stats { gap: 1.5rem; }
    .slide { min-width: 240px; padding: 0.6rem 0.75rem; }
  }
</style>
