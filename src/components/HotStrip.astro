---
interface Token {
  name: string;
  symbol: string;
  trustScore: number;
  slug: string;
}

interface Props {
  tokens: Token[];
}

const { tokens } = Astro.props;
const hot = tokens.sort((a, b) => b.trustScore - a.trustScore).slice(0, 12);
const dup = [...hot, ...hot];
---

<section class="hot-section" data-animate>
  <div class="hot-header">
    <span class="hot-label">Hot Tokens</span>
    <span class="hot-count">{hot.length}</span>
  </div>
  <div class="hot-track-wrap">
    <div class="hot-track">
      {dup.map((t) => {
        const color =
          t.trustScore >= 86 ? "#4488ff" :
          t.trustScore >= 70 ? "#44cc66" :
          t.trustScore >= 31 ? "#ccaa22" :
          "#dd4444";
        return (
          <a href={`/token/${t.slug}`} class="hot-chip">
            <span class="chip-name">{t.name}</span>
            <span class="chip-sym">{t.symbol}</span>
            <span class="chip-score" style={`color: ${color}`}>{t.trustScore}</span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .hot-section {
    margin: 1.5rem 0 2rem;
  }
  .hot-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding: 0 0.25rem;
  }
  .hot-header {
    opacity: 0;
  }
  [data-viewed] .hot-header {
    animation: hotFade 0.5s ease forwards;
  }

  @keyframes hotFade {
    to { opacity: 1; }
  }

  .hot-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(0,240,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .hot-count {
    font-size: 0.6rem;
    color: rgba(0,240,255,0.2);
    background: rgba(0,240,255,0.04);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    border: 1px solid rgba(0,240,255,0.05);
  }
  .hot-track-wrap {
    overflow: hidden;
    mask: linear-gradient(90deg, transparent 0%, #000 4%, #000 96%, transparent 100%);
    -webkit-mask: linear-gradient(90deg, transparent 0%, #000 4%, #000 96%, transparent 100%);
  }
  .hot-track {
    display: flex;
    gap: 0.5rem;
    width: max-content;
    animation: scroll 30s linear infinite;
  }
  .hot-track:hover {
    animation-play-state: paused;
  }
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .hot-chip {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.7rem;
    background: linear-gradient(135deg, rgba(10,12,20,0.8), rgba(8,10,18,0.9));
    border: 1px solid rgba(0,240,255,0.05);
    border-radius: 14px;
    white-space: nowrap;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .hot-chip:hover {
    border-color: rgba(0,240,255,0.15);
    background: rgba(12,16,28,0.95);
    text-decoration: none;
  }
  .chip-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: #c8d8e8;
  }
  .chip-sym {
    font-size: 0.65rem;
    color: #4a5a6a;
  }
  .chip-score {
    font-size: 0.7rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    margin-left: 0.15rem;
  }
</style>
