---
interface Token {
  name: string;
  symbol: string;
  trustScore: number;
  slug: string;
  network?: string;
  chain?: string;
  market?: {
    priceUsd?: number;
    marketCap?: number;
    liquidityUsd?: number;
    volume24h?: number;
  };
  security?: {
    contractAgeDays?: number;
  };
}

interface Props {
  tokens: Token[];
}

const { tokens } = Astro.props;

const sorted = [...tokens]
  .filter((t) => t.security?.contractAgeDays != null)
  .sort((a, b) => (a.security?.contractAgeDays ?? 9999) - (b.security?.contractAgeDays ?? 9999));

const remaining = tokens.filter((t) => t.security?.contractAgeDays == null).reverse();

const newest = [...sorted, ...remaining].slice(0, 10);

function scoreColor(s: number) {
  return s >= 86 ? "#4488ff" : s >= 70 ? "#44cc66" : s >= 31 ? "#ccaa22" : "#dd4444";
}

function fmtPrice(n?: number): string {
  if (n == null) return "-";
  if (n < 0.0001) return `$${n.toExponential(2)}`;
  if (n < 1) return `$${n.toFixed(6)}`;
  return `$${n.toFixed(4)}`;
}
---

<section class="latest" data-animate>
  <div class="latest-header">
    <h2 class="section-title">Newest Discoveries</h2>
    <span class="latest-sub">Recently detected tokens across all chains</span>
  </div>
  <div class="latest-grid">
    {newest.map((t, i) => (
      <a href={`/token/${t.slug}`} class="latest-card" style={`--i:${i}`}>
        <div class="lc-left">
          <span class="lc-rank">{String(i + 1).padStart(2, "0")}</span>
          <div class="lc-info">
            <span class="lc-name">{t.name}</span>
            <span class="lc-sym">{t.symbol}</span>
          </div>
        </div>
        <div class="lc-mid">
          <span class="lc-network">{t.network || t.chain || "?"}</span>
          <span class="lc-price">{fmtPrice(t.market?.priceUsd)}</span>
        </div>
        <div class="lc-right">
          <span class="lc-score" style={{ color: scoreColor(t.trustScore) }}>{t.trustScore}</span>
          <div class="lc-bar-bg">
            <div class="lc-bar" style={`width:${t.trustScore}%;background:${scoreColor(t.trustScore)}`}></div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .latest {
    padding: 2rem 0 3rem;
    position: relative;
  }

  .latest::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,240,255,0.08), transparent);
  }

  .latest-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(0,240,255,0.6);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(-18px);
  }
  [data-viewed] .section-title {
    animation: secDrop 0.6s ease forwards;
  }

  .section-title::before { content: '// '; color: rgba(0,240,255,0.25); }
  .section-title::after { content: ' //'; color: rgba(0,240,255,0.25); }

  @keyframes secDrop {
    to { opacity: 1; transform: translateY(0); }
  }

  .latest-sub {
    font-size: 0.7rem;
    color: #3a4a5a;
    display: block;
    margin-top: 0.3rem;
    letter-spacing: 0.04em;
  }

  .latest-grid {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .latest-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 0.9rem;
    background: linear-gradient(135deg, rgba(10,12,20,0.7), rgba(8,10,18,0.8));
    border: 1px solid rgba(0,240,255,0.04);
    border-radius: 6px;
    opacity: 0;
    transform: translateX(-12px);
  }
  [data-viewed] .latest-card {
    animation: slideIn 0.4s ease forwards;
    animation-delay: calc(var(--i) * 0.06s + 0.8s);
    transition: all 0.2s ease;
    position: relative;
  }

  .latest-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 2px;
    background: rgba(0,240,255,0.06);
    border-radius: 1px;
    transition: all 0.3s;
  }

  .latest-card:hover {
    border-color: rgba(0,240,255,0.12);
    background: rgba(12,16,28,0.9);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .latest-card:hover::before {
    top: 5%;
    bottom: 5%;
    background: rgba(0,240,255,0.3);
    box-shadow: 0 0 8px rgba(0,240,255,0.15);
  }

  @keyframes slideIn {
    to { opacity: 1; transform: translateX(0); }
  }

  .lc-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
    flex: 1;
  }

  .lc-rank {
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(0,240,255,0.2);
    font-variant-numeric: tabular-nums;
    width: 1.4rem;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }

  .lc-info {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
  }

  .lc-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: #c8d8e8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lc-sym {
    font-size: 0.65rem;
    color: #4a5a6a;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .lc-mid {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0.75rem;
    flex-shrink: 0;
  }

  .lc-network {
    font-size: 0.55rem;
    background: rgba(0,240,255,0.05);
    color: rgba(0,240,255,0.4);
    padding: 0.05rem 0.35rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .lc-price {
    font-size: 0.65rem;
    color: #4a5a6a;
    font-variant-numeric: tabular-nums;
  }

  .lc-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .lc-score {
    font-size: 0.8rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    width: 1.8rem;
    text-align: right;
  }

  .lc-bar-bg {
    width: 40px;
    height: 2px;
    background: rgba(255,255,255,0.03);
    border-radius: 1px;
    overflow: hidden;
  }

  .lc-bar {
    height: 100%;
    border-radius: 1px;
    transition: width 0.6s ease;
    box-shadow: 0 0 4px currentColor;
  }

  @media (max-width: 600px) {
    .lc-mid { display: none; }
  }
</style>
