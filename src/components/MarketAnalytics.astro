---
interface Props {
  market: {
    priceUsd: number;
    marketCap: number;
    liquidityUsd: number;
    volume24h: number;
  };
  address: string;
  network: string;
}

const { market, address } = Astro.props;

function fmt(n: number): string {
  if (n >= 1e9) return `$${(n / 1e9).toFixed(2)}B`;
  if (n >= 1e6) return `$${(n / 1e6).toFixed(2)}M`;
  if (n >= 1e3) return `$${(n / 1e3).toFixed(1)}K`;
  return `$${n.toFixed(6)}`;
}

function fmtPrice(n: number): string {
  if (n < 0.0001) return `$${n.toExponential(2)}`;
  return `$${n.toFixed(8)}`;
}

const stats = [
  { label: "Price", value: fmtPrice(market.priceUsd) },
  { label: "Market Cap", value: fmt(market.marketCap) },
  { label: "Liquidity", value: fmt(market.liquidityUsd) },
  { label: "24h Volume", value: fmt(market.volume24h) },
];
---

<div class="market">
  <h3>Market Analytics</h3>
  <div class="stats">
    {stats.map((s) => (
      <div class="stat">
        <span class="stat-label">{s.label}</span>
        <span class="stat-value">{s.value}</span>
      </div>
    ))}
  </div>
  <iframe
    class="chart"
    src={`https://dexscreener.com/${network}/${address}?embed=1&trades=0&info=0`}
    title="DexScreener Chart"
    loading="lazy"
  ></iframe>
</div>

<style>
  .market { margin-bottom: 2rem; }
  h3 { font-size: 1rem; color: #aaa; margin-bottom: 1rem; }
  .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 1rem; }
  .stat {
    background: #1a1a24; padding: 0.75rem; border-radius: 8px; text-align: center;
  }
  .stat-label { display: block; font-size: 0.7rem; color: #888; text-transform: uppercase; }
  .stat-value { display: block; font-size: 1rem; color: #fff; font-weight: 600; margin-top: 0.25rem; font-variant-numeric: tabular-nums; }
  .chart { width: 100%; height: 400px; border: none; border-radius: 8px; background: #1a1a24; }
</style>
