    letter-spacing: -0.02em;
  }
  .logo:hover { text-decoration: none; opacity: 0.9; }
  .nav-links {
    display: flex;
    gap: 0.25rem;
  }
  .nav-links a {
    font-size: 0.8rem;
    color: #888;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    transition: all 0.2s;
    letter-spacing: 0.01em;
  }
  .nav-links a:hover {
