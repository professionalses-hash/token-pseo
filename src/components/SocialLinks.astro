  socials?: Record<string, string>;
  website?: string;
}

const { socials = {}, website = "" } = Astro.props;

const platforms: { key: string; label: string; icon: string }[] = [
  { key: "twitter", label: "Twitter / X", icon: "M18.2 3.2h3.3l-7.2 8.2 8.5 11.2h-6.6l-5.2-6.8-6 6.8H2.7l7.8-8.9L2.4 3.2h6.8l4.7 6.2 5.5-6.2zm-1.2 17.4h1.8L7.1 4.7H5.2L17 20.6z" },
