const active = platforms.filter((p) => socials[p.key]);

const allLinks = [
  ...active.map((p) => ({ label: p.label, url: socials[p.key], icon: p.icon })),
  ...(website ? [{ label: "Website", url: website, icon: "" }] : []),
];
---

{allLinks.length > 0 && (
  <div class="socials">
    <h3>Socials & Links</h3>
    <div class="links">
      {allLinks.map((link) => (
        <a href={link.url} target="_blank" rel="noopener noreferrer" class="link">
          {link.icon && (
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
              <path d={link.icon} />
            </svg>
          )}
          {!link.icon && (
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          )}
          <span>{link.label}</span>
        </a>
      ))}
    </div>
  </div>
)}
{allLinks.length === 0 && (
  <div class="socials empty">
    <h3>Socials & Links</h3>
    <p class="none">No social links available. Data will appear after next scrape cycle.</p>
  </div>
)}

<style>
  .socials { margin-bottom: 2rem; }
  .socials h3 { font-size: 1rem; color: #aaa; margin-bottom: 0.75rem; }
  .links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.45rem 0.9rem; border-radius: 8px;
    background: #1a1a24; border: 1px solid rgba(255,255,255,0.06);
    font-size: 0.8rem; color: #ccc; transition: all 0.2s;
  }
  .link:hover {
    background: #24243a; border-color: rgba(108,140,255,0.2);
    color: #fff; text-decoration: none;
  }
  .none {
    font-size: 0.8rem; color: #555; font-style: italic;
  }
</style>
