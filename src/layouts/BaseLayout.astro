---
import NavBar from "../components/NavBar.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {canonical && <link rel="canonical" href={canonical} />}
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap');
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'JetBrains Mono', -apple-system, BlinkMacSystemFont, monospace;
        background: #08080e;
        color: #c8d0e0;
        line-height: 1.6;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          linear-gradient(rgba(0,240,255,0.015) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,240,255,0.015) 1px, transparent 1px);
        background-size: 48px 48px;
        pointer-events: none;
        z-index: 0;
      }
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0,240,255,0.008) 2px,
          rgba(0,240,255,0.008) 4px
        );
        pointer-events: none;
        z-index: 0;
      }

      .wireframe {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }

      .wireframe-grid {
        position: absolute;
        left: -50%;
        right: -50%;
        bottom: -20%;
        top: -50%;
        background-image:
          linear-gradient(rgba(0,240,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,240,255,0.02) 1px, transparent 1px);
        background-size: 64px 64px;
        transform: rotateX(72deg);
        transform-origin: center bottom;
        animation: wireScroll 24s linear infinite;
      }

      @keyframes wireScroll {
        0% { transform: rotateX(72deg) translateY(0); }
        100% { transform: rotateX(72deg) translateY(64px); }
      }

      .wireframe-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.5;
      }

      .wireframe-svg path {
        fill: none;
        stroke: rgba(0,240,255,0.08);
        stroke-width: 1;
      }

      .wireframe-svg .wire-pulse {
        stroke: rgba(0,240,255,0.18);
        stroke-width: 1.5;
        stroke-dasharray: 6 40;
        animation: dataFlow 4s linear infinite;
      }

      .wireframe-svg .wire-pulse:nth-child(2) { animation-delay: 1s; }
      .wireframe-svg .wire-pulse:nth-child(3) { animation-delay: 2s; }
      .wireframe-svg .wire-pulse:nth-child(4) { animation-delay: 3s; }

      @keyframes dataFlow {
        0% { stroke-dashoffset: 0; opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { stroke-dashoffset: -100; opacity: 0; }
      }

      .wireframe-svg .wire-glow {
        stroke: rgba(0,240,255,0.04);
        stroke-width: 3;
        filter: blur(3px);
        animation: glowPulse 6s ease-in-out infinite alternate;
      }

      @keyframes glowPulse {
        0% { opacity: 0.3; }
        100% { opacity: 1; }
      }

      .wireframe-svg circle {
        fill: rgba(0,240,255,0.06);
        stroke: rgba(0,240,255,0.1);
        stroke-width: 0.5;
      }

      .wireframe-svg .node-core {
        fill: rgba(0,240,255,0.3);
        stroke: none;
        animation: nodeCore 4s ease-in-out infinite alternate;
      }

      .wireframe-svg .node-core:nth-child(even) { animation-delay: 2s; }

      @keyframes nodeCore {
        0% { opacity: 0.2; r: 1.5; }
        100% { opacity: 0.8; r: 2.5; }
      }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        position: relative;
        z-index: 1;
      }
      a { color: #00c8ff; text-decoration: none; transition: color 0.2s; }
      a:hover { color: #00f0ff; text-decoration: underline; }
      ::selection { background: rgba(0,200,255,0.25); color: #fff; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #0a0a12; }
      ::-webkit-scrollbar-thumb { background: #1a2a3a; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #2a3a4a; }
    </style>
  </head>
  <body>
    <div class="wireframe" aria-hidden="true">
      <div class="wireframe-grid"></div>
      <svg class="wireframe-svg" viewBox="0 0 1000 800" preserveAspectRatio="none">
        <defs>
          <filter id="wgBlur"><feGaussianBlur stdDeviation="1.5"/></filter>
        </defs>
        <g filter="url(#wgBlur)">
          <path d="M50,100 L150,320 L300,144 L450,440 L600,220 L750,380 L880,120" class="wire-glow"/>
          <path d="M50,100 L150,320 L300,144 L450,440 L600,220 L750,380 L880,120" class="wire-pulse"/>
          <path d="M50,100 L150,320 L300,144 L450,440 L600,220 L750,380 L880,120" class="wire-pulse"/>
        </g>
        <g filter="url(#wgBlur)">
          <path d="M100,60 L250,150 L420,80 L550,180 L700,100 L920,50" class="wire-glow"/>
          <path d="M100,60 L250,150 L420,80 L550,180 L700,100 L920,50" class="wire-pulse"/>
          <path d="M100,60 L250,150 L420,80 L550,180 L700,100 L920,50" class="wire-pulse"/>
        </g>
        <g filter="url(#wgBlur)">
          <path d="M100,60 L50,100 M250,150 L150,320 M420,80 L300,144 M550,180 L600,220 M700,100 L750,380 M920,50 L880,120" class="wire-glow"/>
          <path d="M100,60 L50,100 M250,150 L150,320 M420,80 L300,144 M550,180 L600,220 M700,100 L750,380 M920,50 L880,120" class="wire-pulse"/>
        </g>
        <g filter="url(#wgBlur)">
          <path d="M150,320 L100,480 L50,100 M300,144 L450,440 L600,220 M750,380 L820,700 L880,120 M450,440 L350,600 L200,700 L100,480 M600,220 L700,720 L820,700 M150,320 L350,600 M300,144 L200,700" class="wire-glow"/>
          <path d="M150,320 L100,480 L50,100 M300,144 L450,440 L600,220 M750,380 L820,700 L880,120 M450,440 L350,600 L200,700 L100,480 M600,220 L700,720 L820,700 M150,320 L350,600 M300,144 L200,700" class="wire-pulse"/>
          <path d="M150,320 L100,480 L50,100 M300,144 L450,440 L600,220 M750,380 L820,700 L880,120 M450,440 L350,600 L200,700 L100,480 M600,220 L700,720 L820,700 M150,320 L350,600 M300,144 L200,700" class="wire-pulse"/>
        </g>
        <g filter="url(#wgBlur)">
          <path d="M150,320 L250,150 M300,144 L420,80 M600,220 L550,180 M750,380 L700,100 M880,120 L920,50 M820,700 L920,50 M700,720 L920,50" class="wire-glow"/>
          <path d="M150,320 L250,150 M300,144 L420,80 M600,220 L550,180 M750,380 L700,100 M880,120 L920,50 M820,700 L920,50 M700,720 L920,50" class="wire-pulse"/>
        </g>
        <g filter="url(#wgBlur)">
          <path d="M100,60 L300,144 L450,440 L600,220 L750,380 L880,120" class="wire-glow"/>
          <path d="M100,60 L300,144 L450,440 L600,220 L750,380 L880,120" class="wire-pulse"/>
        </g>
        <circle cx="50" cy="100" r="6" fill="rgba(0,240,255,0.04)" stroke="rgba(0,240,255,0.08)"/>
        <circle cx="150" cy="320" r="7" fill="rgba(0,240,255,0.05)" stroke="rgba(0,240,255,0.1)"/>
        <circle cx="300" cy="144" r="6" fill="rgba(0,240,255,0.04)" stroke="rgba(0,240,255,0.08)"/>
        <circle cx="450" cy="440" r="8" fill="rgba(0,240,255,0.06)" stroke="rgba(0,240,255,0.12)"/>
        <circle cx="600" cy="220" r="6" fill="rgba(0,240,255,0.04)" stroke="rgba(0,240,255,0.08)"/>
        <circle cx="750" cy="380" r="7" fill="rgba(0,240,255,0.05)" stroke="rgba(0,240,255,0.1)"/>
        <circle cx="880" cy="120" r="6" fill="rgba(0,240,255,0.04)" stroke="rgba(0,240,255,0.08)"/>
        <circle cx="100" cy="60" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="250" cy="150" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="420" cy="80" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="550" cy="180" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="700" cy="100" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="920" cy="50" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="100" cy="480" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="350" cy="600" r="6" fill="rgba(0,240,255,0.04)" stroke="rgba(0,240,255,0.08)"/>
        <circle cx="200" cy="700" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="820" cy="700" r="6" fill="rgba(0,240,255,0.04)" stroke="rgba(0,240,255,0.08)"/>
        <circle cx="700" cy="720" r="5" fill="rgba(0,240,255,0.03)" stroke="rgba(0,240,255,0.06)"/>
        <circle cx="450" cy="440" r="2.5" class="node-core"/>
        <circle cx="150" cy="320" r="2" class="node-core"/>
        <circle cx="750" cy="380" r="2" class="node-core"/>
        <circle cx="300" cy="144" r="1.5" class="node-core"/>
        <circle cx="600" cy="220" r="1.5" class="node-core"/>
        <circle cx="350" cy="600" r="2" class="node-core"/>
        <circle cx="820" cy="700" r="2" class="node-core"/>
      </svg>
    </div>
    <NavBar />
    <div class="container">
      <slot />
    </div>
  </body>
</html>
