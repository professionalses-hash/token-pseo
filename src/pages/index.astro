---
import BaseLayout from "../layouts/BaseLayout.astro";
import HotStrip from "../components/HotStrip.astro";
import HeroSlider from "../components/HeroSlider.astro";
import Features from "../components/Features.astro";
import LatestTokens from "../components/LatestTokens.astro";
import SecurityDashboard from "../components/SecurityDashboard.astro";
import ChainExplorer from "../components/ChainExplorer.astro";
import MarketPulse from "../components/MarketPulse.astro";
import ContactReview from "../components/ContactReview.astro";

const tokens = Object.values(
  import.meta.glob("../../data/tokens.json", { eager: true })
).map((m) => m.default).flat();

const tokenList = tokens;
---

<BaseLayout title="Token PSEO — Security Audits & Trust Scores" description="Live security analysis and trust scores for the latest tokens across Ethereum, BSC, and Solana.">
  <HeroSlider tokens={tokenList} />

  <HotStrip tokens={tokenList} />

  <Features />

  <LatestTokens tokens={tokenList} />

  <SecurityDashboard tokens={tokenList} />

  <ChainExplorer tokens={tokenList} />

  <MarketPulse tokens={tokenList} />

  <ContactReview />
</BaseLayout>
