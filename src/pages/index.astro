---
import BaseLayout from "../layouts/BaseLayout.astro";
import TokenCard from "../components/TokenCard.astro";
import HotStrip from "../components/HotStrip.astro";
import HeroSlider from "../components/HeroSlider.astro";

const tokens = Object.values(
  import.meta.glob("../../data/tokens.json", { eager: true })
).map((m) => m.default).flat();

const tokenList = tokens;
---

<BaseLayout title="Token PSEO — Security Audits & Trust Scores" description="Live security analysis and trust scores for the latest tokens across Ethereum, BSC, and Solana.">
  <HeroSlider tokens={tokenList} />

  <HotStrip tokens={tokenList} />

  <section class="list">
    <div class="list-header">
      <h2>Token Audit Index</h2>
      <span class="list-count">{tokenList.length} tokens</span>
    </div>
    {tokenList.length === 0 && <p class="empty">No tokens loaded yet. Run the scraper first.</p>}
    <div class="grid">
      {tokenList.map((t) => (
        <TokenCard
          name={t.name}
          symbol={t.symbol}
          network={t.network || t.chain}
          trustScore={t.trustScore}
          priceUsd={t.market.priceUsd}
          marketCap={t.market.marketCap}
          liquidityUsd={t.market.liquidityUsd}
          slug={t.slug}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .list-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding: 0 0.25rem;
  }
  .list-header h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #ddd;
  }
  .list-count {
    font-size: 0.8rem;
    color: #555;
  }
  .grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .empty {
    text-align: center;
    color: #666;
    padding: 3rem 0;
  }
  @media (max-width: 600px) {
    h1 { font-size: 1.75rem; }
  }
</style>
