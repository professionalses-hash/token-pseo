---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import TrustMeter from "../../components/TrustMeter.astro";
import SecurityPanel from "../../components/SecurityPanel.astro";
import Tokenomics from "../../components/Tokenomics.astro";
import MarketAnalytics from "../../components/MarketAnalytics.astro";

export function getStaticPaths() {
  return Object.values(
    import.meta.glob("../../../data/tokens.json", { eager: true })
  ).map((m) => m.default).flat().map((t) => ({
    params: { slug: t.slug },
    props: { token: t },
  }));
}

const { token } = Astro.props;

const title = `${token.name} (${token.symbol}) Contract Security Audit, Chart & Scam Check`;
const desc = `Live security analysis for ${token.name}. Trust Score: ${token.trustScore}/100. Check contract security, tokenomics, and market data.`;
---

<BaseLayout title={title} description={desc}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: title,
    description: desc,
    datePublished: new Date().toISOString(),
    about: { "@type": "Thing", name: token.name, identifier: token.address },
  })} />

  <main>
    <a href="/" class="back">&larr; Back to all tokens</a>
    <div class="page-grid">
      <div class="left">
        <Hero name={token.name} symbol={token.symbol} address={token.address} network={token.network || token.chain} />
        <TrustMeter score={token.trustScore} name={token.name} badges={token.badges} />
        <SecurityPanel security={token.security} />
      </div>
      <div class="right">
        <Tokenomics tokenomics={token.tokenomics} />
        <MarketAnalytics market={token.market} address={token.address} network={token.network || token.chain} />
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .back { display: inline-block; margin-bottom: 1.5rem; font-size: 0.85rem; color: #6c8cff; }
  .page-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  @media (max-width: 768px) { .page-grid { grid-template-columns: 1fr; } }
</style>
